{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": ["**/*.ts", "fixtures/*.json"]
}
